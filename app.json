{
  "expo": {
    "name": "Land of Leal",
    "slug": "land-of-leal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0B1E"
    },
    "ios": {
      "usesAppleSignIn": true,
      "supportsTablet": true,
      "bundleIdentifier": "com.landofleal.app",
      "associatedDomains": ["webcredentials:<your-associated-domain>"],
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "UIStatusBarStyle": "UIStatusBarStyleLightContent"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F0B1E"
      },
      "package": "com.landofleal.app",
      "versionCode": 1
    },
    "extra": {
      "privyAppId": "cmlvjiwj900cg0cl517cvw39l",
      "privyClientId": "client-WY6W4FEhCEWDzLUzJXFHiyCotafD1NYDTAihp6v5Wt6S6",
      "passkeyAssociatedDomain": "https://<your-associated-domain>",
      "heliusApiKey": "YOUR_HELIUS_API_KEY"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.5"
          },
          "android": {
            "compileSdkVersion": 35
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
